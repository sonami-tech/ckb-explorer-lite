# CKB Networks configuration.
# Format: Name|Type|IsArchive|URL
# - Name: Display name for the network.
# - Type: mainnet, testnet, or devnet.
# - IsArchive: true if archive mode (set_block_height) is supported, false otherwise.
# - URL: RPC endpoint URL.
# Networks are auto-detected by iterating VITE_CKB_NETWORK_0, _1, _2, etc.
VITE_CKB_NETWORK_0=Mainnet Archive|mainnet|true|http://127.0.0.1:8114
VITE_CKB_NETWORK_1=Mainnet|mainnet|false|http://127.0.0.1:8114
VITE_CKB_NETWORK_2=Testnet|testnet|false|http://127.0.0.1:18114

# Polling interval for latest blocks and transactions (milliseconds).
VITE_POLL_INTERVAL_MS=8000
